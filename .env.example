# ============================================================
# Personal Finance ETL — environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================


# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# Path to your local DuckDB file (created automatically on first run)
DUCKDB_PATH=./data/finance.duckdb


# ------------------------------------------------------------
# Source data
# ------------------------------------------------------------

# Folder where you drop your exported bank/card CSVs
# This should be OUTSIDE the repo if using real transaction data
RAW_DATA_DIR=./data/raw

# CSV format exported by your bank (options: chase, bofa, wellsfargo, generic)
BANK_CSV_FORMAT=generic

# CSV format exported by your credit card provider
CARD_CSV_FORMAT=generic


# ------------------------------------------------------------
# dbt
# ------------------------------------------------------------

# dbt profile to use (must match a profile name in transform/profiles.yml)
DBT_PROFILE=personal_finance

# dbt target environment (options: dev, prod)
DBT_TARGET=dev


# ------------------------------------------------------------
# Pipeline behaviour
# ------------------------------------------------------------

# Log level (options: DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log output file — leave blank to log to console only
LOG_FILE=./logs/pipeline.log

# Set to true to skip loading and only run dbt transformations
SKIP_EXTRACT=false

# Set to true to drop and recreate all tables on each run
FULL_REFRESH=false


# ------------------------------------------------------------
# Notifications (optional)
# ------------------------------------------------------------

# Slack webhook URL — leave blank to disable pipeline alerts
SLACK_WEBHOOK_URL=

# Email address to notify on pipeline failure — leave blank to disable
ALERT_EMAIL=
